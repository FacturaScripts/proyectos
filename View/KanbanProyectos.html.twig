{% extends "Master/MenuBgTemplate.html.twig" %}

{% block body %}
    {{ parent() }}

    <div class="container-fluid">
        {% if fsc.projects is empty %}
            <div class="row p-3 mt-md-5">
                <div class="col text-center">
                    <div class="mb-3">
                        <i class="fa-solid fa-inbox fa-3x text-secondary"></i>
                    </div>
                    <p class="mb-3">{{ trans('no-projects') }}</p>
                    <a href="EditProyecto" class="btn btn-success">
                        <i class="fa-solid fa-plus me-1"></i> {{ trans('project') }}
                    </a>
                </div>
            </div>
        {% else %}
        <div class="py-3">
            <div class="project-header card shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex gap-3 align-items-start flex-wrap flex-md-nowrap">
                        <div class="project-header-icon text-secondary">
                            {% if fsc.project.privado %}
                                <i class="fa-solid fa-lock"></i>
                            {% else %}
                                <i class="fa-brands fa-stack-overflow"></i>
                            {% endif %}
                        </div>
                        <div class="flex-grow-1 w-100">
                            <div class="row g-2 align-items-end">
                                <div class="col-md">
                                    <label class="form-label small mb-1 text-muted">{{ trans('project') }}</label>
                                    <select class="form-select" id="projectSelector"
                                            onchange="window.location.href='KanbanProyectos?idproyecto=' + this.value">
                                        {% for project in fsc.projects %}
                                            <option value="{{ project.idproyecto }}"
                                                    {{ project.idproyecto == fsc.project.idproyecto ? 'selected' : '' }}>
                                                {{ project.privado ? '🔒 ' : '' }}{{ project.nombre }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                {% if fsc.project.idproyecto %}
                                    <div class="col-auto">
                                        <a href="EditTareaProyecto?idproyecto={{ fsc.project.idproyecto }}" class="btn btn-success">
                                            <i class="fa-solid fa-plus me-1"></i> {{ trans('task') }}
                                        </a>
                                    </div>
                                {% endif %}
                            </div>

                            {% if fsc.project.idproyecto %}
                                <hr class="my-3">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                    <h5 class="mb-0">
                                        <a href="EditProyecto?code={{ fsc.project.idproyecto }}" class="text-decoration-none">
                                            {{ fsc.project.nombre }}
                                        </a>
                                    </h5>
                                    {% if fsc.projectStatus and fsc.projectStatus.nombre %}
                                        <span class="badge" style="background-color: {{ fsc.projectStatus.color ?: '#6c757d' }};">
                                            {{ fsc.projectStatus.nombre }}
                                        </span>
                                    {% endif %}
                                </div>
                                {% if fsc.project.descripcion %}
                                    <p class="text-muted small mb-2 mt-2">{{ fsc.project.descripcion | nl2br }}</p>
                                {% endif %}
                                <div class="d-flex flex-wrap gap-3 small text-muted mt-2">
                                    {% if fsc.project.fechainicio or fsc.project.fechafin %}
                                        <span>
                                            <i class="fa-solid fa-calendar-days me-1"></i>
                                            {{ fsc.project.fechainicio ?: '—' }}
                                            <i class="fa-solid fa-arrow-right-long mx-1"></i>
                                            {{ fsc.project.fechafin ?: '—' }}
                                        </span>
                                    {% endif %}
                                    {% if fsc.project.codcliente %}
                                        <span>
                                            <i class="fa-solid fa-building me-1"></i>
                                            {{ fsc.project.codcliente }}
                                        </span>
                                    {% endif %}
                                    {% if fsc.project.nick %}
                                        <span>
                                            <i class="fa-solid fa-user me-1"></i>
                                            {{ fsc.project.nick }}
                                        </span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% if fsc.project.idproyecto %}
            <div class="row flex-nowrap kanban-board pb-3">
                {% for phase in fsc.phases %}
                    {% set tasks = fsc.tasksByPhase[phase.idfase] ?? [] %}
                    {% if phase.tipo is same as(0) %}
                        {% set phaseColor = 'bg-success text-white' %}
                        {% set badgeColor = 'bg-light text-success' %}
                    {% elseif phase.tipo is same as(1) %}
                        {% set phaseColor = 'bg-danger text-white' %}
                        {% set badgeColor = 'bg-light text-danger' %}
                    {% elseif phase.tipo is same as(2) %}
                        {% set phaseColor = 'bg-info text-white' %}
                        {% set badgeColor = 'bg-light text-info' %}
                    {% else %}
                        {% set phaseColor = '' %}
                        {% set badgeColor = 'bg-secondary' %}
                    {% endif %}
                    <div class="col kanban-col">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center {{ phaseColor }}">
                                <strong>{{ phase.nombre }}</strong>
                                <span class="badge {{ badgeColor }}">{{ tasks | length }}</span>
                            </div>
                            <div class="card-body kanban-column p-2"
                                 data-phase-id="{{ phase.idfase }}"
                                 style="min-height: 150px; overflow-y: auto;">
                                {% for task in tasks %}
                                    <div class="card mb-2 kanban-task shadow-sm" data-task-id="{{ task.idtarea }}">
                                        <div class="card-body p-2">
                                            <a href="EditTareaProyecto?code={{ task.idtarea }}"
                                               class="fw-bold text-decoration-none">
                                                {{ task.nombre }}
                                            </a>
                                            {% if task.descripcion %}
                                                <p class="text-muted small mb-0 mt-1">
                                                    {{ task.descripcion | length > 100 ? task.descripcion | slice(0, 100) ~ '...' : task.descripcion }}
                                                </p>
                                            {% endif %}
                                            {% if task.fechafin %}
                                                <div class="mt-1">
                                                    <small class="text-muted">
                                                        <i class="fa-solid fa-calendar-check"></i> {{ task.fechafin }}
                                                    </small>
                                                </div>
                                            {% endif %}
                                            {% if task.nick %}
                                                <div class="mt-1">
                                                    <small class="text-muted">
                                                        <i class="fa-solid fa-user"></i> {{ task.nick }}
                                                    </small>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-info">
                {{ trans('no-data') }}
            </div>
        {% endif %}
        {% endif %}
    </div>
{% endblock %}

{% block css %}
    {{ parent() }}

    <style>
        .project-header-icon {
            font-size: 3.5rem;
            line-height: 1;
            min-width: 3.5rem;
            text-align: center;
        }
        .kanban-board {
            overflow-x: auto;
        }
        .kanban-col {
            flex: 1 1 0%;
        }
        .kanban-task {
            cursor: grab;
            transition: box-shadow 0.2s;
        }
        .kanban-task:active {
            cursor: grabbing;
        }
        .kanban-task.sortable-ghost {
            opacity: 0.4;
            background-color: #e9ecef;
        }
        .kanban-task.sortable-chosen {
            box-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.2);
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('Plugins/Proyectos/node_modules/sortablejs/Sortable.min.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var editable = {{ fsc.project.editable and fsc.permissions.allowUpdate ? 'true' : 'false' }};

            document.querySelectorAll('.kanban-column').forEach(function (column) {
                new Sortable(column, {
                    group: 'kanban',
                    animation: 150,
                    ghostClass: 'sortable-ghost',
                    chosenClass: 'sortable-chosen',
                    disabled: !editable,
                    onEnd: function (evt) {
                        if (evt.from === evt.to && evt.oldIndex === evt.newIndex) {
                            return;
                        }

                        var taskId = evt.item.dataset.taskId;
                        var newPhaseId = evt.to.dataset.phaseId;

                        // update badge counts
                        var fromBadge = evt.from.closest('.card').querySelector('.badge');
                        var toBadge = evt.to.closest('.card').querySelector('.badge');
                        fromBadge.textContent = evt.from.children.length;
                        toBadge.textContent = evt.to.children.length;

                        fetch('KanbanProyectos?action=move-task', {
                            method: 'POST',
                            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                            body: 'idtarea=' + taskId + '&idfase=' + newPhaseId
                        }).then(function (response) {
                            return response.json();
                        }).then(function (data) {
                            if (!data.ok) {
                                location.reload();
                            }
                        }).catch(function () {
                            location.reload();
                        });
                    }
                });
            });
        });
    </script>
{% endblock %}
