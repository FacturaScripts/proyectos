{% extends "Master/MenuBgTemplate.html.twig" %}

{% block body %}
    <div class="container-fluid">

        {# Encabezado #}
        <div class="row mt-3 mb-4">
            <div class="col-12 text-center">
                <h1 class="h3 mb-0">
                    <i class="fa-brands fa-stack-overflow me-2"></i>
                    {{ trans('projects') | capitalize }} — {{ trans('report') | capitalize }}
                </h1>
            </div>
        </div>

        {# KPI Cards #}
        <div class="row justify-content-center">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-warning shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                    {{ trans('total-projects') }}
                                </div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{ fsc.totalProjects }}</div>
                            </div>
                            <div class="col-auto">
                                <i class="fa-brands fa-stack-overflow fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                    {{ trans('open-projects-total') }}
                                </div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{ fsc.openProjects }}</div>
                            </div>
                            <div class="col-auto">
                                <i class="fa-solid fa-lock-open fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-info shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                    {{ trans('open-projects-last-month') }}
                                </div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{ fsc.openProjectsLastMonth }}</div>
                            </div>
                            <div class="col-auto">
                                <i class="fa-solid fa-calendar-days fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-success shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    {{ trans('open-projects-last-year') }}
                                </div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{ fsc.openProjectsLastYear }}</div>
                            </div>
                            <div class="col-auto">
                                <i class="fa-solid fa-calendar fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Gráficos por mes y por año #}
        <div class="row">
            <div class="col-12 col-lg-8 mb-4">
                <div class="card shadow">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-chart-bar me-2"></i>
                            {{ trans('projects-by-month') }}
                        </h6>
                    </div>
                    <div class="card-body">
                        <div id="chartByMonth"></div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-4 mb-4">
                <div class="card shadow">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-chart-bar me-2"></i>
                            {{ trans('projects-by-year') }}
                        </h6>
                    </div>
                    <div class="card-body">
                        <div id="chartByYear"></div>
                    </div>
                </div>
            </div>
        </div>

        {# Tabla por estado #}
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-chart-pie me-2"></i>
                            {{ trans('projects-by-status') }}
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>{{ trans('status') }}</th>
                                        <th class="text-end">{{ trans('quantity') }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for row in fsc.projectsByStatus %}
                                        <tr>
                                            <td>
                                                <a href="{{ row.editable ? 'ListProyecto' : 'ListProyecto?activetab=ListProyecto-closed' }}">
                                                    {% if row.color %}
                                                        <span class="d-inline-block me-2 rounded"
                                                              style="width:14px;height:14px;background-color:{{ row.color }};vertical-align:middle;"></span>
                                                    {% else %}
                                                        <span class="d-inline-block me-2 rounded bg-secondary"
                                                              style="width:14px;height:14px;vertical-align:middle;"></span>
                                                    {% endif %}
                                                    {{ row.nombre }}
                                                </a>
                                            </td>
                                            <td class="text-end fw-bold">{{ row.total }}</td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="2" class="text-center text-muted py-3">
                                                {{ trans('no-data') }}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Tablas por administrador y cliente #}
        <div class="row">
            <div class="col-12 col-lg-6 mb-4">
                <div class="card shadow">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-user me-2"></i>
                            {{ trans('projects-by-nick') }}
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="p-3 pb-0">
                            <div id="chartByNick"></div>
                        </div>
                        <div class="text-end px-3 py-1 border-top">
                            <a class="small text-muted text-decoration-none" data-bs-toggle="collapse"
                               href="#collapseNick" role="button" aria-expanded="false">
                                <i class="fa-solid fa-list fa-xs me-1"></i> Ver detalle
                            </a>
                        </div>
                        <div class="collapse" id="collapseNick">
                            <div class="table-responsive" style="max-height:380px;overflow-y:auto;">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>{{ trans('admin') }}</th>
                                            <th class="text-end">{{ trans('quantity') }}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for row in fsc.projectsByNick %}
                                            <tr>
                                                <td>
                                                    {% if row.nick %}
                                                        <a href="EditUser?code={{ row.nick }}">{{ row.nick }}</a>
                                                    {% else %}
                                                        ---
                                                    {% endif %}
                                                </td>
                                                <td class="text-end fw-bold">{{ row.total }}</td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="2" class="text-center text-muted py-3">{{ trans('no-data') }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6 mb-4">
                <div class="card shadow">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-building me-2"></i>
                            {{ trans('projects-by-client') }}
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="p-3 pb-0">
                            <div id="chartByClient"></div>
                        </div>
                        <div class="text-end px-3 py-1 border-top">
                            <a class="small text-muted text-decoration-none" data-bs-toggle="collapse"
                               href="#collapseClient" role="button" aria-expanded="false">
                                <i class="fa-solid fa-list fa-xs me-1"></i> Ver detalle
                            </a>
                        </div>
                        <div class="collapse" id="collapseClient">
                            <div class="table-responsive" style="max-height:380px;overflow-y:auto;">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>{{ trans('customer') }}</th>
                                            <th class="text-end">{{ trans('quantity') }}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for row in fsc.projectsByClient %}
                                            <tr>
                                                <td>
                                                    {% if row.codcliente %}
                                                        <a href="EditCliente?code={{ row.codcliente }}">{{ row.nombre ?: row.codcliente }}</a>
                                                    {% else %}
                                                        ---
                                                    {% endif %}
                                                </td>
                                                <td class="text-end fw-bold">{{ row.total }}</td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="2" class="text-center text-muted py-3">{{ trans('no-data') }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('Plugins/Proyectos/node_modules/apexcharts/dist/apexcharts.min.js') }}"></script>
    <script>
        var monthData  = {{ fsc.projectsByMonth  | json_encode | raw }};
        var yearData   = {{ fsc.projectsByYear   | json_encode | raw }};
        var nickData   = {{ fsc.projectsByNick   | json_encode | raw }};
        var clientData = {{ fsc.projectsByClient | json_encode | raw }};

        function donutChart(selector, data, labelKey) {
            if (!data.length) { return; }
            var MAX = 5;
            var labels, series;
            if (data.length > MAX) {
                labels = data.slice(0, MAX).map(function (r) { return r[labelKey] || '---'; });
                series = data.slice(0, MAX).map(function (r) { return parseInt(r.total); });
                var rest = data.slice(MAX).reduce(function (sum, r) { return sum + parseInt(r.total); }, 0);
                labels.push('Otros');
                series.push(rest);
            } else {
                labels = data.map(function (r) { return r[labelKey] || '---'; });
                series = data.map(function (r) { return parseInt(r.total); });
            }
            new ApexCharts(document.querySelector(selector), {
                series: series,
                chart: {type: 'donut', height: 240, toolbar: {show: false}},
                labels: labels,
                legend: {position: 'bottom', fontSize: '12px'},
                plotOptions: {pie: {donut: {size: '60%'}}},
                dataLabels: {enabled: false}
            }).render();
        }

        $(document).ready(function () {
            var monthLabels = Object.keys(monthData).map(function (k) {
                var p = k.split('-');
                return new Date(p[0], p[1] - 1).toLocaleDateString('es-ES', {month: 'short', year: '2-digit'});
            });

            new ApexCharts(document.querySelector('#chartByMonth'), {
                series: [{name: '{{ trans('projects') | capitalize }}', data: Object.values(monthData)}],
                chart: {height: 300, type: 'bar', toolbar: {show: true}},
                plotOptions: {bar: {borderRadius: 2, dataLabels: {position: 'top'}}},
                dataLabels: {enabled: false},
                xaxis: {categories: monthLabels, axisBorder: {show: false}, axisTicks: {show: false}},
                yaxis: {labels: {formatter: function (v) { return Math.round(v); }}},
                colors: ['#4e73df']
            }).render();

            new ApexCharts(document.querySelector('#chartByYear'), {
                series: [{name: '{{ trans('projects') | capitalize }}', data: Object.values(yearData)}],
                chart: {height: 300, type: 'bar', toolbar: {show: true}},
                plotOptions: {bar: {borderRadius: 2, dataLabels: {position: 'top'}}},
                dataLabels: {enabled: false},
                xaxis: {categories: Object.keys(yearData), axisBorder: {show: false}, axisTicks: {show: false}},
                yaxis: {labels: {formatter: function (v) { return Math.round(v); }}},
                colors: ['#1cc88a']
            }).render();

            donutChart('#chartByNick',   nickData,   'nick');
            donutChart('#chartByClient', clientData, 'nombre');
        });
    </script>
{% endblock %}
